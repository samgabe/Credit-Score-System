# 🚀 CREDIT SCORE API - ENVIRONMENT VARIABLES
# Copy this file to .env and update with your actual values

# 🔐 JWT Configuration
SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 🗄️ Database Configuration
# PostgreSQL Database Connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=credit_score_db
DB_USER=user
DB_PASSWORD=password

# Full Database URL (constructed from above)
# Alternative: Direct database URL
# DATABASE_URL=postgresql://user:password@localhost:5432/credit_score_db

# 🧪 Test Database (for testing)
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_NAME=credit_score_test_db
TEST_DB_USER=user
TEST_DB_PASSWORD=password

# 📊 Application Configuration
APP_NAME=Credit Score API
APP_VERSION=1.0.0
DEBUG=true

# 🏊 Database Connection Pool Settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# 📁 Data Source Configuration
DATA_SOURCE=database
CSV_DIRECTORY=csv_data

# 🚀 Server Configuration
HOST=0.0.0.0
PORT=8000

# 📧 Email Configuration (if needed)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=noreply@creditscore.com

# 🔒 Security Settings
# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 📈 Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# 🏦 File Upload Settings
MAX_FILE_SIZE=10485760  # 10MB in bytes
UPLOAD_DIRECTORY=uploads

# 🎯 Credit Score Configuration
MIN_CREDIT_SCORE=300
MAX_CREDIT_SCORE=850
DEFAULT_CREDIT_SCORE=500

# 📊 Analytics Configuration
ANALYTICS_CACHE_TTL=300  # 5 minutes
ANALYTICS_BATCH_SIZE=1000

# 🔧 Development Settings
DEVELOPMENT_MODE=true
ENABLE_PROFILING=false
ENABLE_DEBUG_ROUTES=true
