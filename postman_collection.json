{
  "info": {
    "name": "Credit Score API - User Profile & Credit Integration",
    "description": "Complete API collection for testing user profile enhancement and credit score integration",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api/v1",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. User Management",
      "item": [
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('user_id', jsonData.id);",
                  "    pm.test('User created successfully', function() {",
                  "        pm.expect(jsonData).to.have.property('id');",
                  "        pm.expect(jsonData).to.have.property('fullname');",
                  "        pm.expect(jsonData).to.have.property('national_id');",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullname\": \"John Doe\",\n  \"national_id\": 12345678,\n  \"phone_number\": \"+254712345678\",\n  \"email\": \"john@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users",
              "host": ["{{base_url}}"],
              "path": ["users"]
            },
            "description": "Create a new user with full profile information"
          },
          "response": []
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/users/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["users", "{{user_id}}"]
            },
            "description": "Retrieve user profile by user ID"
          },
          "response": []
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullname\": \"John Smith\",\n  \"phone_number\": \"+254787654321\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["users", "{{user_id}}"]
            },
            "description": "Update user profile (fullname and phone_number only)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. Credit Score",
      "item": [
        {
          "name": "Calculate Credit Score",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/users/{{user_id}}/credit-score",
              "host": ["{{base_url}}"],
              "path": ["users", "{{user_id}}", "credit-score"]
            },
            "description": "Calculate and store credit score for a user"
          },
          "response": []
        },
        {
          "name": "Get Current Credit Score",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/users/{{user_id}}/credit-score",
              "host": ["{{base_url}}"],
              "path": ["users", "{{user_id}}", "credit-score"]
            },
            "description": "Retrieve the most recent credit score for a user"
          },
          "response": []
        },
        {
          "name": "Get Credit Score History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/users/{{user_id}}/credit-score/history",
              "host": ["{{base_url}}"],
              "path": ["users", "{{user_id}}", "credit-score", "history"]
            },
            "description": "Retrieve all historical credit scores for a user"
          },
          "response": []
        },
        {
          "name": "Get Credit Score History (Date Range)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/users/{{user_id}}/credit-score/history?start_date=2024-01-01&end_date=2024-12-31",
              "host": ["{{base_url}}"],
              "path": ["users", "{{user_id}}", "credit-score", "history"],
              "query": [
                {
                  "key": "start_date",
                  "value": "2024-01-01",
                  "description": "Start date (YYYY-MM-DD)"
                },
                {
                  "key": "end_date",
                  "value": "2024-12-31",
                  "description": "End date (YYYY-MM-DD)"
                }
              ]
            },
            "description": "Retrieve credit score history filtered by date range"
          },
          "response": []
        }
      ]
    },
    {
      "name": "3. Error Cases",
      "item": [
        {
          "name": "Create User - Duplicate National ID",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullname\": \"Jane Doe\",\n  \"national_id\": 12345678,\n  \"phone_number\": \"+254700000000\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users",
              "host": ["{{base_url}}"],
              "path": ["users"]
            },
            "description": "Test duplicate national ID error (409 Conflict)"
          },
          "response": []
        },
        {
          "name": "Create User - Validation Error",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullname\": \"\",\n  \"national_id\": 12345678,\n  \"phone_number\": \"+254712345678\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users",
              "host": ["{{base_url}}"],
              "path": ["users"]
            },
            "description": "Test validation error with empty fullname (400 Bad Request)"
          },
          "response": []
        },
        {
          "name": "Get User - Not Found",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/users/00000000-0000-0000-0000-000000000000",
              "host": ["{{base_url}}"],
              "path": ["users", "00000000-0000-0000-0000-000000000000"]
            },
            "description": "Test user not found error (404 Not Found)"
          },
          "response": []
        },
        {
          "name": "Get Credit Score - User Not Found",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/users/00000000-0000-0000-0000-000000000000/credit-score",
              "host": ["{{base_url}}"],
              "path": ["users", "00000000-0000-0000-0000-000000000000", "credit-score"]
            },
            "description": "Test credit score retrieval for non-existent user (404 Not Found)"
          },
          "response": []
        },
        {
          "name": "Update User - No Fields",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/users/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["users", "{{user_id}}"]
            },
            "description": "Test update with no fields provided (400 Bad Request)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "4. Health Check",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["health"]
            },
            "description": "Check if the API is running"
          },
          "response": []
        }
      ]
    }
  ]
}
